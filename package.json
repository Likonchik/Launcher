{
  "name": "project-minecraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:launcher",
    "dev:launcher": "sh -c '. \"$HOME/.cargo/env\" 2>/dev/null || true; cargo run --manifest-path launcher-slint/Cargo.toml'",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run build:launcher",
    "build:web": "tsc && vite build",
    "build:launcher": "sh -c '. \"$HOME/.cargo/env\" 2>/dev/null || true; cargo build --release --manifest-path launcher-slint/Cargo.toml'",
    "dev:dashboard": "npm --prefix dashboard run dev",
    "build:dashboard": "npm --prefix dashboard run build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.10.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
